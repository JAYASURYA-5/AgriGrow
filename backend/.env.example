# Flask Auth Backend Environment

# Secret Keys (generate with python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me_super_secret_key
JWT_SECRET_KEY=change_me_jwt_secret_key

# Database (SQLite for dev, MySQL for prod)
SQLALCHEMY_DATABASE_URI=sqlite:///auth.db
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://username:password@localhost:3306/auth_db

# CORS origins (add your frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT config
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=604800  # 7 days

