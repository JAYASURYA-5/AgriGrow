# =============================================================================
# AGRIGROW ENHANCED DISEASE PREDICTOR - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your API keys for full functionality
# This file should NEVER be committed to version control
# =============================================================================

# =============================================================================
# CLARIFAI API (Recommended - Best accuracy for crop disease)
# Setup: https://www.clarifai.com
# =============================================================================
CLARIFAI_API_KEY=
CLARIFAI_USER_ID=
CLARIFAI_APP_ID=

# =============================================================================
# GOOGLE CLOUD VISION API (Secondary - Backup for feature detection)
# Setup: https://console.cloud.google.com
# =============================================================================
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# IBM WATSON VISUAL RECOGNITION (Optional)
# Setup: https://cloud.ibm.com
# =============================================================================
IBM_API_KEY=
IBM_WATSON_ENDPOINT=

# =============================================================================
# MICROSOFT AZURE COMPUTER VISION (Optional)
# Setup: https://azure.microsoft.com
# =============================================================================
AZURE_API_KEY=
AZURE_ENDPOINT=

# =============================================================================
# FLASK APPLICATION SETTINGS
# =============================================================================
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_SECRET_KEY=change-me-in-production

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
MODEL_DIR=./models
MODEL_FILE=./models/plant_disease_model.h5
CLASS_MAPPING_FILE=./models/class_mapping.json
IMAGE_SIZE=224

# =============================================================================
# PREDICTION SETTINGS
# =============================================================================
# Confidence thresholds for disease detection
MIN_CONFIDENCE_THRESHOLD=60
HIGH_CONFIDENCE_THRESHOLD=85

# Ensemble prediction weights
LOCAL_MODEL_WEIGHT=0.35
FEATURE_ANALYSIS_WEIGHT=0.25
API_PREDICTIONS_WEIGHT=0.40

# =============================================================================
# DATABASE SETTINGS (if using persistent storage)
# =============================================================================
DATABASE_URL=sqlite:///agrigrow.db
SQLALCHEMY_TRACK_MODIFICATIONS=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/disease_predictor.log

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Enable CORS for specific origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_IMAGE_SIZE=10485760  # 10MB in bytes
ALLOWED_IMAGE_FORMATS=jpeg,jpg,png,webp

# =============================================================================
# API RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # seconds (1 hour)

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=3600

# =============================================================================
# NOTIFICATION SETTINGS (for alert systems)
# =============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_RECIPIENTS=farmer@example.com

# =============================================================================
# FEATURE FLAGS (for gradual rollout)
# =============================================================================
ENABLE_ENSEMBLE_PREDICTION=true
ENABLE_CLARIFAI_API=true
ENABLE_GOOGLE_VISION_API=true
ENABLE_TENSORFLOW_HUB=true
ENABLE_CACHING=true
ENABLE_DETAILED_LOGGING=false

# =============================================================================
# DEVELOPMENT SETTINGS (DO NOT USE IN PRODUCTION)
# =============================================================================
DEBUG_MODE=false
DUMMY_API_RESPONSE=false  # Use mock responses for testing
TEST_MODE=false
